# InnovativeFlow - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================================
# RAZORPAY CONFIGURATION (Payment Processing)
# ============================================================
# Get these from https://dashboard.razorpay.com/app/settings/api-keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id  # Public key for frontend

# ============================================================
# DATABASE CONFIGURATION (Supabase or your PostgreSQL)
# ============================================================
# Get these from Supabase dashboard or your database provider
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_PUBLIC_URL=postgresql://user:password@host:5432/database

# Supabase specific
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================================
# AUTHENTICATION (Supabase Auth or Better Auth)
# ============================================================
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_generated_secret
BETTER_AUTH_URL=http://localhost:3000  # Change to your domain in production

# ============================================================
# AI INTEGRATION (OpenAI, Claude, or Groq)
# ============================================================
# Get these from respective API providers
OPENAI_API_KEY=sk-your_openai_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
GROQ_API_KEY=gsk-your_groq_key

# ============================================================
# EMAIL SERVICE (Resend, SendGrid, or Mailgun)
# ============================================================
# Get these from email service providers
RESEND_API_KEY=re_your_resend_key
SENDGRID_API_KEY=SG.your_sendgrid_key
MAILGUN_API_KEY=your_mailgun_key
MAILGUN_DOMAIN=mg.yourdomain.com

# Email sending
NEXT_PUBLIC_SUPPORT_EMAIL=support@innovativeflow.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@innovativeflow.com

# ============================================================
# STORAGE CONFIGURATION (Supabase Storage or AWS S3)
# ============================================================
# Supabase Storage (recommended)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=documents
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage

# AWS S3 (alternative)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1

# ============================================================
# MONITORING & ANALYTICS
# ============================================================
# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://posthog.company.com

# ============================================================
# APPLICATION SETTINGS
# ============================================================
# Application environment
NODE_ENV=development  # development | production | test

# App URL (for redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=InnovativeFlow

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_TIMEOUT=30000  # milliseconds

# ============================================================
# FEATURE FLAGS
# ============================================================
# Enable/disable features
NEXT_PUBLIC_ENABLE_PAYMENTS=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_ADMIN=true
NEXT_PUBLIC_MAINTENANCE_MODE=false

# ============================================================
# WEBHOOK SECRETS
# ============================================================
# Get these from respective service dashboards
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================
# DEBUGGING
# ============================================================
# Set to true for verbose logging (disable in production)
DEBUG=false
DEBUG_API=false
DEBUG_AUTH=false
DEBUG_PAYMENTS=false

# ============================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================
# Google Analytics
NEXT_PUBLIC_GA_ID=G-your_google_analytics_id

# Segment
NEXT_PUBLIC_SEGMENT_WRITE_KEY=your_segment_key

# Intercom (customer support)
NEXT_PUBLIC_INTERCOM_APP_ID=your_intercom_id

# ============================================================
# Notes
# ============================================================
# - Variables starting with NEXT_PUBLIC_ are exposed to the browser
# - Never commit .env.local to version control
# - In production, add these as environment variables in Vercel dashboard
# - See PAYMENT_SETUP.md for detailed Razorpay setup instructions
# - See README.md for complete setup guide
